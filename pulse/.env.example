# Copia este fichero a .env y rellena lo que uses. Todo es opcional salvo el puerto.
PORT=4321

# --- Módulo IA: sondeo de percepción de marca y share de recomendación ---
# Con una sola clave ya funciona; cada una añade un modelo más al sondeo.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# PERPLEXITY_API_KEY=

# --- Alertas por Telegram (gratis): crea un bot con @BotFather ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Google Safe Browsing (gratis, opcional): listas negras ---
# SAFE_BROWSING_API_KEY=

# --- Fase Search Console (más adelante) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
